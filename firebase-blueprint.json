{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase User ID" },
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phoneNumber": { "type": "string", "description": "Phone number with country code" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile photo" },
        "provider": { "type": "string", "enum": ["google", "phone", "email"], "description": "Primary login provider used" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the account was last updated" }
      },
      "required": ["uid", "name", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles stored by their unique UID"
    },
    "/_health/check": {
      "schema": { "type": "object", "properties": { "status": { "type": "string" } } },
      "description": "System health check document"
    }
  }
}
