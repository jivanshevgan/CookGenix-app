rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'jeevanshevgan13@gmail.com';
    }

    // Phase 4: Entity Validation
    function isValidUser(data) {
      return data.user_id == request.auth.uid
          && data.uid == request.auth.uid
          && data.name is string && data.name.size() <= 128
          && data.email is string && data.email.size() <= 256
          && data.createdAt is string // Server sends ISO string in current setup
          && data.updatedAt is string;
    }

    function isValidRecipe(data) {
      return data.user_id == request.auth.uid
          && data.name is string && data.name.size() <= 200
          && data.ingredients is list && data.ingredients.size() <= 50
          && (data.ingredients.size() == 0 || data.ingredients[0] is string)
          && data.method is string && data.method.size() <= 5000
          && data.savedAt is string;
    }

    function isValidFeedback(data) {
      return data.user_id == request.auth.uid
          && data.rating is int && data.rating >= 1 && data.rating <= 5
          && data.message is string && data.message.size() <= 1000
          && data.timestamp is string;
    }

    // Collection Matches
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidUser(incoming());
      allow list: if isAdmin();
    }

    match /recipes/{recipeId} {
      allow get: if isSignedIn() && existing().user_id == request.auth.uid;
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      
      allow create: if isSignedIn() && isValidRecipe(incoming());
      
      allow update: if isSignedIn() 
          && existing().user_id == request.auth.uid
          && isValidRecipe(incoming())
          && incoming().user_id == existing().user_id;
          
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow list, get: if isAdmin();
      // Users cannot update or delete feedback once submitted
    }
  }
}
