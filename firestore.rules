rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User entity validation
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128
          && data.name is string && data.name.size() > 0 && data.name.size() <= 128
          && (data.email == null || (data.email is string && data.email.size() <= 256))
          && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 32))
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024))
          && data.provider in ['google', 'phone', 'email']
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    match /users/{uid} {
      allow get: if isOwner(uid);
      allow list: if false; // Users cannot list other users
      
      allow create: if isOwner(uid) 
          && isValidId(uid) 
          && isValidUser(incoming())
          && incoming().uid == uid
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;

      allow update: if isOwner(uid)
          && isValidUser(incoming())
          && incoming().uid == existing().uid
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phoneNumber', 'photoURL', 'provider', 'updatedAt']);
      
      allow delete: if isOwner(uid);
    }
  }
}
